# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Customer Service AI
#
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Optional — defaults shown below ──────────────────────────────────────────

# CORS: comma-separated list of allowed Streamlit origins
# When running with Docker Compose, the app container is also added automatically.
CORS_ORIGINS=http://localhost:8501

# Groq LLM settings
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1024

# RAG / ChromaDB settings
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_TOP_K=4
RAG_FETCH_K=20
RAG_MMR_LAMBDA=0.6
CHROMA_DIR=data/chroma_db

# Dataset filename (relative to data/raw/)
BITEXT_CSV=Bitext_Sample_Customer_Support_Training_Dataset_27K_responses-v11.csv

# ── Docker-only ───────────────────────────────────────────────────────────────
# Overrides the backend URL used by the Streamlit container.
# Set to http://api:8000 when running with Docker Compose (already default).
# Set to http://localhost:8000 when running without Docker.
# API_BASE_URL=http://api:8000
